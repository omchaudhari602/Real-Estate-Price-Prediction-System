# Example environment variables for local development
# Copy this file to `.env` and fill in secure values before running the app.

# Backend configuration
SECRET_KEY=replace-with-a-secure-random-value
# Use one of: sqlite:///relative.db  OR postgresql://user:pass@host:5432/dbname
DATABASE_URL=sqlite:///houseprices.db

# Optional MLflow tracking server (leave blank to use local tracking dir)
MLFLOW_TRACKING_URI=

# Token expiration in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=60
# Example environment variables\n+MLFLOW_TRACKING_URI=http://localhost:5000\n+DATABASE_URL=postgresql://user:password@postgres:5432/db\n+SECRET_KEY=replace-me\n