{
  "uid": "houseprice-main",
  "title": "House Price Prediction Dashboard",
  "tags": [ "machine-learning", "fastapi" ],
  "timezone": "browser",
  "refresh": "5s",
  "panels": [
    {
      "type": "timeseries",
      "title": "API Request Latency (p95)",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(app_request_latency_seconds_bucket[5m])) by (le))",
          "format": "time_series"
        }
      ],
      "gridPos": {"x": 0, "y": 0, "w": 12, "h": 8}
    },
    {
      "type": "timeseries",
      "title": "Prediction Engine Latency (p95)",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(prediction_latency_seconds_bucket[5m])) by (le))",
          "format": "time_series"
        }
      ],
      "gridPos": {"x": 12, "y": 0, "w": 12, "h": 8}
    },
    {
      "type": "stat",
      "title": "Failed Requests (Last 5m)",
      "targets": [
        {
          "expr": "sum(rate(app_requests_failed_total[5m]))",
          "format": "time_series"
        }
      ],
      "gridPos": {"x": 0, "y": 8, "w": 12, "h": 5}
    },
    {
      "type": "stat",
      "title": "Total API Requests (Last 5m)",
      "targets": [
        {
          "expr": "sum(rate(app_request_latency_seconds_count[5m]))",
          "format": "time_series"
        }
      ],
      "gridPos": {"x": 12, "y": 8, "w": 12, "h": 5}
    }
  ],
  "schemaVersion": 38,
  "version": 1
}